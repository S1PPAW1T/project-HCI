# MongoDB
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname

# OpenAI
OPENAI_API_KEY=sk-your-api-key-here

# Firebase Admin SDK (for Vercel - use environment variables)
# For local development, use serviceAccountKey.json file instead
FIREBASE_PROJECT_ID=hci-project-9fc9a
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@hci-project-9fc9a.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your-client-id
FIREBASE_CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/...
FIREBASE_STORAGE_BUCKET=hci-project-9fc9a.firebasestorage.app
FIREBASE_DATABASE_URL=https://hci-project-9fc9a.firebaseio.com

# API
PORT=5000
API_URL=http://localhost:5000

# JWT (optional)
JWT_SECRET=your-secret-key-here
